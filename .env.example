# ===== JARVIS AI · 舆情监控大屏 =====

# Web 服务端口
DASHBOARD_PORT=8765

# 服务监听地址（本地用 127.0.0.1，Docker/局域网用 0.0.0.0）
DASHBOARD_HOST=127.0.0.1

# ===== 可选：AI 对话功能 =====
# 舆情监控大屏无需配置以下项也能正常运行。
# 如需 JARVIS AI 对话，填写 OpenAI 兼容 API 地址与 Token。
# Token 仅后端持有，通过 /api/chat 代理转发，不会暴露到前端。
OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_API_TOKEN=
